# ローカル実行用の環境変数サンプル。コピーして .env を作り値を入れる。
#   cp .env.example .env
# GitHub Actions ではこれらを「リポジトリの Secrets」に登録する（.env は使わない）。

# ── Googleカレンダー ─────────────────────────────
# 予定を書き込むカレンダーのID（カレンダー設定 > 「カレンダーの統合」に表示）
GOOGLE_CALENDAR_ID=

# サービスアカウントのJSONキー全文を1行で。ローカルなら service-account.json を読んで貼る。
# 例: {"type":"service_account","project_id":"...","private_key":"-----BEGIN...","client_email":"...@...iam.gserviceaccount.com",...}
GOOGLE_SERVICE_ACCOUNT_JSON=

# ── スマホ通知（どちらか片方でOK。両方入れれば両方に届く）──
# Discord: サーバー設定 > 連携サービス > ウェブフック で作成したURL
DISCORD_WEBHOOK_URL=

# ntfy: 好きな長めのトピック名（例: pokeca-chusen-3f9a2）。スマホのntfyアプリで同じトピックを購読
NTFY_TOPIC=

# ── 任意設定 ─────────────────────────────────────
# 相場取得(駿河屋)を止めたい場合は false
# PRICE_ENABLED=true
# まとめ記事URLを差し替えたい場合
# NYUKA_NOW_URL=https://nyuka-now.com/archives/2459
