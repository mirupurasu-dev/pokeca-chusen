{
  "name": "pokeca-chusen",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "ポケモンカードの抽選スケジュールを自動収集し、期待値(相場-定価)を算出、Googleカレンダー登録とスマホ通知(Discord/ntfy)を行う自動化ツール。GitHub Actionsで定期実行。",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "once": "node src/index.js --dry-run",
    "dump": "node scripts/dump.js"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "cheerio": "^1.0.0",
    "googleapis": "^144.0.0",
    "playwright": "^1.49.1"
  }
}
